# Vercel Environment Variables
#
# Set these in Vercel dashboard > Project Settings > Environment Variables.
# All three are REQUIRED for production.
#
# These are build-time variables — they are baked into the JS bundle.
# Changing them requires a redeploy (Vercel > Deployments > Redeploy).
#
# See docs/deploy.md for the full deployment guide.

# Backend API URL — all /api calls go here.
# Must be the Railway deployment URL with no trailing slash.
VITE_BACKEND_URL=https://your-app.up.railway.app

# Supabase project URL.
# Find at: Supabase Dashboard > Settings > API > Project URL (or Connect dialog)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase publishable key (public, safe for frontend). Format: sb_publishable_...
# Find at: Supabase Dashboard > Settings > API keys > Publishable key
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
