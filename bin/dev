#!/bin/bash
set -e
cd "$(dirname "$0")/.."

_load_supabase_env() {
  while IFS='=' read -r key raw_value; do
    value="${raw_value%\"}"
    value="${value#\"}"
    case "$key" in
      API_URL)
        export SUPABASE_URL="${SUPABASE_URL:-$value}"
        export VITE_SUPABASE_URL="${VITE_SUPABASE_URL:-$value}"
        ;;
      DB_URL)
        export DATABASE_URL="${DATABASE_URL:-$value}"
        ;;
      ANON_KEY)
        export PUBLIC_SUPABASE_ANON_KEY="${PUBLIC_SUPABASE_ANON_KEY:-$value}"
        export VITE_SUPABASE_ANON_KEY="${VITE_SUPABASE_ANON_KEY:-$value}"
        ;;
      SERVICE_ROLE_KEY)
        export SUPABASE_SERVICE_KEY="${SUPABASE_SERVICE_KEY:-$value}"
        ;;
      JWT_SECRET)
        export JWT_SECRET="${JWT_SECRET:-$value}"
        ;;
    esac
  done < <(supabase status -o env)
}

_ensure_supabase() {
  if ! supabase status -o env >/dev/null 2>&1; then
    echo "Starting local Supabase stack..."
    supabase start
  fi
  _load_supabase_env
}

export DATABASE_URL="${DATABASE_URL:-postgresql://postgres:postgres@127.0.0.1:54322/postgres}"

case "${1:-help}" in
  test)
    _ensure_supabase
    supabase db reset --local --yes >/dev/null
    _load_supabase_env
    echo "Running all tests..."
    uv run pytest "${@:2}"
    npm run test:run --prefix frontend
    ;;
  test:be)
    _ensure_supabase
    supabase db reset --local --yes >/dev/null
    _load_supabase_env
    echo "Running backend tests..."
    uv run pytest "${@:2}"
    ;;
  test:fe)
    echo "Running frontend tests..."
    npm run test:run --prefix frontend
    ;;
  test:e2e)
    echo "Running e2e tests..."
    npx --prefix e2e playwright test --config=e2e/playwright.config.ts "${@:2}"
    ;;
  fmt)
    echo "Formatting code..."
    uv run ruff format .
    ;;
  lint)
    echo "Linting..."
    uv run ruff check .
    ;;
  lint:fe)
    echo "Linting frontend..."
    npm run lint --prefix frontend
    ;;
  fmt:fe)
    echo "Formatting frontend..."
    npm run format --prefix frontend
    ;;
  commit)
    echo "Commitizen commit..."
    uv run cz commit
    ;;
  container)
    echo "Starting devcontainer..."
    cd .devcontainer && docker-compose up -d
    ;;
  server)
    _ensure_supabase
    echo "Starting backend dev server..."
    PYTHONPATH=backend:. uv run uvicorn server:app --reload --host 0.0.0.0 --port 8000 --app-dir backend
    ;;
  ui)
    _ensure_supabase
    echo "Starting frontend dev server..."
    npm run dev --prefix frontend
    ;;
  provision)
    _ensure_supabase
    echo "Provisioning org + departments..."
    PYTHONPATH=backend:. uv run python -m devtools.scripts.provision "${@:2}"
    ;;
  import)
    _ensure_supabase
    echo "Importing Hike data..."
    PYTHONPATH=backend:. uv run python -m devtools.scripts.import_hike "${@:2}"
    ;;
  eval)
    echo "Running evals..."
    PYTHONPATH=backend:. uv run python -m devtools.evals "${@:2}"
    ;;
  create-admin)
    echo "Creating admin user..."
    PYTHONPATH=backend:. uv run python backend/scripts/create_admin.py "${@:2}"
    ;;
  verify)
    echo "Running pre-deploy verification..."
    PYTHONPATH=backend:. uv run python backend/scripts/verify_deploy.py "${@:2}"
    ;;
  db)
    echo "Starting local Supabase stack..."
    supabase start
    _load_supabase_env
    echo "Supabase ready at ${SUPABASE_URL}"
    echo "Postgres ready at ${DATABASE_URL}"
    ;;
  db:stop)
    echo "Stopping local Supabase stack..."
    supabase stop
    ;;
  db:reset)
    _ensure_supabase
    echo "Resetting local Supabase database..."
    supabase db reset --local --yes
    _load_supabase_env
    echo "Supabase reset complete at ${DATABASE_URL}"
    ;;
  help|*)
    echo "sku-ops Dev Commands:"
    echo "  ./bin/dev test [args]      - Run all tests (backend + frontend)"
    echo "  ./bin/dev test:be [args]   - Run backend tests only"
    echo "  ./bin/dev test:fe          - Run frontend tests only"
    echo "  ./bin/dev test:e2e [args]  - Run Playwright e2e tests"
    echo "  ./bin/dev fmt              - Format all Python code with ruff"
    echo "  ./bin/dev lint             - Lint all Python code with ruff"
    echo "  ./bin/dev lint:fe          - Lint frontend with ESLint"
    echo "  ./bin/dev fmt:fe           - Format frontend with Prettier"
    echo "  ./bin/dev commit           - Commitizen commit"
    echo "  ./bin/dev server           - Start backend dev server"
    echo "  ./bin/dev ui               - Start frontend dev server"
    echo "  ./bin/dev provision [--dev] - Provision org + departments (+ dev user)"
    echo "  ./bin/dev import [flags]   - Import Hike data (--vendors, --products)"
    echo "  ./bin/dev eval [args]      - Run LLM evals"
    echo "  ./bin/dev create-admin     - Create/update admin user in DB"
    echo "  ./bin/dev verify [args]    - Pre-deploy verification (pass --url to also hit a live server)"
    echo "  ./bin/dev container        - Start devcontainer"
    echo "  ./bin/dev db               - Start local Supabase stack"
    echo "  ./bin/dev db:stop          - Stop local Supabase stack"
    echo "  ./bin/dev db:reset         - Reset local Supabase DB from migrations + seed"
    ;;
esac
