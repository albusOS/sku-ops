# Backend API base URL.
# In dev: leave unset (Vite proxies /api to localhost:8000 automatically).
# In production with separate frontend host: set to your backend URL.
# VITE_BACKEND_URL=https://api.your-domain.com

# Dev-only: auto-login as dev@supply-yard.local (no login screen).
# Requires: bridge mode + ./bin/dev provision --dev. Never use in production.
# VITE_BYPASS_AUTH=1

# Supabase — required in production, optional in dev.
# Leave unset in dev to use the local /api/auth/login bridge instead.
# In production: set both to your Supabase project values.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Sentry — optional. Set to enable frontend error tracking.
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
