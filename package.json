{
  "name": "sku-ops",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && ENV=development python -m uvicorn server:app --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "cd frontend && npm run dev",
    "test:backend": "cd backend && .venv/bin/python -m pytest tests/ -x -q",
    "test:frontend": "cd frontend && npm run test",
    "install:backend": "cd backend && pip install -r requirements-dev.txt",
    "install:frontend": "cd frontend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
